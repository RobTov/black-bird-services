# Mailtrap API Token for sending contact form emails
# Get yours at: https://mailtrap.io → Email Sending → Sending Domains → [Your Domain] → API
# IMPORTANT: This must be an Email Sending API token, NOT a Testing (sandbox) token.
MAILTRAP_PASS=your_mailtrap_api_token_here

# Optional: sender email (defaults to info@norbwebsite.com if not set)
# This email/domain MUST be verified in Mailtrap Email Sending → Sending Domains
MAILTRAP_SENDER=info@norbwebsite.com
