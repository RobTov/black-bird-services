# Mailtrap API Token for sending contact form emails
# Get yours at: https://mailtrap.io → Email Testing → My Inbox → Integrations → Server → Transactions → API
MAILTRAP_PASS=your_mailtrap_api_token_here

# Optional: sender email (defaults to info@norbwebsite.com if not set)
MAILTRAP_SENDER=info@norbwebsite.com
