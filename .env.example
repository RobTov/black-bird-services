# Mailtrap SMTP settings for sending contact form emails
# Get them at: https://mailtrap.io → Email Sending → Sending Domains → [Your Domain] → SMTP
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=api
MAILTRAP_PASS=your_mailtrap_smtp_password_here

# Sender email (domain MUST be verified in Mailtrap Email Sending → Sending Domains)
MAILTRAP_SENDER=info@norbwebsite.com
